APP_NAME="Boilerplate Caracoders"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_VE
APP_TIMEZONE=America/Caracas

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# LOG_FORMAT=json  # Requires additional formatter configuration in config/logging.php — see ADR-007 before activating
# LOG_SECURITY_DAYS=90

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=boilerplate_laravel13
DB_USERNAME=postgres
DB_PASSWORD=postgres

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@boilerplate-laravel13.test"
MAIL_FROM_NAME="${APP_NAME}"

MINIO_ROOT_USER=minio-laravel13
MINIO_ROOT_PASSWORD=minio-laravel13-secret
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=boilerplate-laravel13-local

AWS_ACCESS_KEY_ID="${MINIO_ROOT_USER}"
AWS_SECRET_ACCESS_KEY="${MINIO_ROOT_PASSWORD}"
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET="${MINIO_BUCKET}"
AWS_ENDPOINT="${MINIO_ENDPOINT}"
AWS_URL="${MINIO_ENDPOINT}/${MINIO_BUCKET}"
AWS_USE_PATH_STYLE_ENDPOINT=true

ANTHROPIC_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_URL=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small
COHERE_API_KEY=
DEEPSEEK_API_KEY=
ELEVENLABS_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
JINA_API_KEY=
MISTRAL_API_KEY=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=
OPENROUTER_API_KEY=
VOYAGEAI_API_KEY=
XAI_API_KEY=

AI_COPILOT_ENABLED=false
AI_COPILOT_PROVIDER=gemini
AI_COPILOT_MODEL=gemini-2.5-flash-lite

VITE_APP_NAME="${APP_NAME}"
