                            </CardDescription>
                        </CardHeader>
                        <CardContent className="space-y-4">
{{ formFields }}
                        </CardContent>
                    </Card>

                    <div className="flex items-center gap-3">
                        <Button type="submit" disabled={processing}>{processing ? 'Guardando…' : 'Guardar'}</Button>
                        <Button type="button" variant="outline" onClick={() => router.visit(cancelHref)} disabled={processing}>Cancelar</Button>
                    </div>
                </>
            )}
        </Form>
    );
